#include <stdio.h>
#include <unistd.h>
#include <stdlib.h>
#include <sys/wait.h>
int main()
{
    pid_t pid;
    pid=fork();
    if(pid==0){
        execlp("ls","ls","-1",NULL);
        printf("execution failed\n");
        exit(1);
    }
    else if(pid>0){
        wait(NULL);
        printf("Parent Process\n");
        printf("Child process completed.\n");
    }
    else{
        printf("fork failed");
    }

}