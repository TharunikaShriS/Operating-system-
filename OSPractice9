#include <stdio.h>
#define SIZE 5

int buffer[SIZE];
int front = -1, rear = -1;

void produce(int item) {
    if (rear == SIZE - 1) {
        printf("Buffer is Full! Cannot produce.\n");
        return;
    }

    if (front == -1)
        front = 0;

    buffer[++rear] = item;
    printf("Produced: %d\n", item);
}

void consume() {
    if (front == -1 || front > rear) {
        printf("Buffer is Empty! Nothing to consume.\n");
        return;
    }

    printf("Consumed: %d\n", buffer[front]);
    front++;

    // Reset queue when empty
    if (front > rear)
        front = rear = -1;
}

void display() {
    if (front == -1) {
        printf("Buffer is Empty.\n");
        return;
    }

    printf("Buffer: ");
    for (int i = front; i <= rear; i++)
        printf("%d ", buffer[i]);
    printf("\n");
}

int main() {
    int choice, item;

    while (1) {
        printf("\n--- Bounded Buffer Menu ---\n");
        printf("1. Produce\n");
        printf("2. Consume\n");
        printf("3. Display Buffer\n");
        printf("4. Exit\n");
        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                printf("Enter item to produce: ");
                scanf("%d", &item);
                produce(item);
                break;

            case 2:
                consume();
                break;

            case 3:
                display();
                break;

            case 4:
                return 0;

            default:
                printf("Invalid choice!\n");
        }
    }

    return 0;
}