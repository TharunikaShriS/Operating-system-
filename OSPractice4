#include <stdio.h>

int main() {
    int n, i;
    int pid[10], bt[10];

    printf("Enter the number of processes: ");
    scanf("%d", &n);

    // Input process IDs and burst times
    for(i = 0; i < n; i++) {
        printf("\nEnter Process ID: ");
        scanf("%d", &pid[i]);

        printf("Enter Burst Time for Process %d: ", pid[i]);
        scanf("%d", &bt[i]);
    }

    printf("\n--- Scheduler Execution (FCFS) ---\n");

    // Execute processes one by one
    for(i = 0; i < n; i++) {
        printf("Executing Process %d (Burst Time = %d)\n", pid[i], bt[i]);

        // Simulate execution
        for(int j = 1; j <= bt[i]; j++) {
            printf("Process %d is running... %d\n", pid[i], j);
        }

        printf("Process %d completed.\n\n", pid[i]);
    }

    printf("All processes executed successfully.\n");

    return 0;
}