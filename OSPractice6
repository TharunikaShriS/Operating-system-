#include <stdio.h>

int main() {
    int pages[50], frame[10];
    int n, frames, i, j;
    int front = 0, pageFaults = 0, found;

    printf("Enter number of pages: ");
    scanf("%d", &n);

    printf("Enter page reference string: ");
    for(i = 0; i < n; i++)
        scanf("%d", &pages[i]);

    printf("Enter number of frames: ");
    scanf("%d", &frames);

    // Initialize frames
    for(i = 0; i < frames; i++)
        frame[i] = -1;

    printf("\nPage\tFrames\n");

    for(i = 0; i < n; i++) {
        found = 0;

        // Check if page is already in a frame
        for(j = 0; j < frames; j++) {
            if(frame[j] == pages[i]) {
                found = 1;
                break;
            }
        }

        if(!found) {
            // Replace the oldest page (FIFO)
            frame[front] = pages[i];
            front = (front + 1) % frames;
            pageFaults++;
        }

        printf("%d\t", pages[i]);
        for(j = 0; j < frames; j++) {
            if(frame[j] == -1)
                printf("- ");
            else
                printf("%d ", frame[j]);
        }

        if(found)
            printf("(Hit)");
        else
            printf("(Fault)");

        printf("\n");
    }

    printf("\nTotal Page Faults = %d\n", pageFaults);

    return 0;
}