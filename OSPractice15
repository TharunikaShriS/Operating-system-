#include <stdio.h>
#include <unistd.h>
#include <stdlib.h>
#include <sys/wait.h>

int main()
{
    int i;
    pid_t pid;

    for(i = 1; i <= 3; i++)
    {
        pid = fork();

        if(pid == 0)
        {
            printf("Child %d\n", i);
            printf("PID  = %d\n", getpid());
            printf("PPID = %d\n\n", getppid());

            exit(0);
        }
    }

   
    for(i = 1; i <= 3; i++)
    {
        wait(NULL);
    }

    printf("Parent Process\n");
    printf("Parent PID = %d\n", getpid());

    return 0;
}