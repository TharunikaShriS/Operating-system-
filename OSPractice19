#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>

int main() {
    int src, dest;
    char buffer[100];
    int bytes;

    char text[] = "Hello! This is sample text.\nWelcome to file copy program.\n";

    src = open("source.txt", O_WRONLY | O_CREAT | O_TRUNC, 0644);
    if (src == -1) {
        printf("Error creating source file.\n");
        return 1;
    }

    write(src, text, sizeof(text) - 1);
    close(src);

    src = open("source.txt", O_RDONLY);

    dest = open("destination.txt", O_WRONLY | O_CREAT | O_TRUNC, 0644);

    while ((bytes = read(src, buffer, sizeof(buffer))) > 0) {
        write(dest, buffer, bytes);
    }

    close(src);
    close(dest);

    printf("File copied successfully.\n");

    return 0;
}