#include <stdio.h>
#define MAX 10

int queue[MAX];
int front = -1, rear = -1;

void enqueue(int pid) {
    if (rear == MAX - 1) {
        printf("Ready Queue is Full!\n");
        return;
    }

    if (front == -1)
        front = 0;

    queue[++rear] = pid;
    printf("Process %d added to Ready Queue.\n", pid);
}

void dequeue() {
    if (front == -1 || front > rear) {
        printf("Ready Queue is Empty!\n");
        return;
    }

    printf("Process %d is selected for execution.\n", queue[front]);
    front++;

    if (front > rear) {
        front = rear = -1; // Reset queue
    }
}

void display() {
    if (front == -1) {
        printf("Ready Queue is Empty!\n");
        return;
    }

    printf("Ready Queue: ");
    for (int i = front; i <= rear; i++) {
        printf("P%d ", queue[i]);
    }
    printf("\n");
}

int main() {
    int choice, pid;

    while (1) {
        printf("\n--- Ready Queue Simulation ---\n");
        printf("1. Add Process (Enqueue)\n");
        printf("2. Execute Process (Dequeue)\n");
        printf("3. Display Ready Queue\n");
        printf("4. Exit\n");
        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                printf("Enter Process ID: ");
                scanf("%d", &pid);
                enqueue(pid);
                break;

            case 2:
                dequeue();
                break;

            case 3:
                display();
                break;

            case 4:
                return 0;

            default:
                printf("Invalid choice!\n");
        }
    }

    return 0;
}