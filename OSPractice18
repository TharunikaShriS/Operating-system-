#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>
#include <string.h>

int main()
{
    int fd;
    char data[] = "Name: Rahul\nRoll No: 101\nDepartment: CSE\n";
    char buffer[100];
    int bytesRead;

    fd = creat("student.txt", 0644);

    if (fd == -1)
    {
        printf("Error creating file.\n");
        return 1;
    }
    close(fd);

    fd = open("student.txt", O_WRONLY);

    if (fd == -1)
    {
        printf("Error opening file for writing.\n");
        return 1;
    }

    write(fd, data, strlen(data));

    close(fd);

    fd = open("student.txt", O_RDONLY);

    if (fd == -1)
    {
        printf("Error opening file for reading.\n");
        return 1;
    }

    printf("Contents of student.txt:\n\n");


    while ((bytesRead = read(fd, buffer, sizeof(buffer))) > 0)
    {
        write(1, buffer, bytesRead);  
    }


    close(fd);

    return 0;
}